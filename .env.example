# ============================================================
# .env.example — Variáveis de ambiente do IntelliDoc
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o .env com valores reais no Git
# ============================================================

# ── OpenAI ──────────────────────────────────────────────────
# Chave de API da OpenAI — obtenha em https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Pinecone ─────────────────────────────────────────────────
# Chave de API do Pinecone — obtenha em https://app.pinecone.io
PINECONE_API_KEY=pcsk_...

# Nome do índice vetorial criado no Pinecone
PINECONE_INDEX_NAME=intellidoc

# ── Tesseract OCR ────────────────────────────────────────────
# Caminho do executável do Tesseract na sua máquina
# Windows (padrão): C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux           : /usr/bin/tesseract
# Mac             : /usr/local/bin/tesseract
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── SSL (redes corporativas) ─────────────────────────────────
# Necessário apenas em redes corporativas com certificado próprio
# Execute fix_ssl.py para gerar os valores corretos
# SSL_CERT_FILE=caminho/para/cacert.pem
# REQUESTS_CA_BUNDLE=caminho/para/cacert.pem